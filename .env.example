# ─── Telegram Bot ─────────────────────────────────────────────────────────────
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
ADMIN_IDS=123456789                # comma-separated for multiple admins

# ─── API Auth ─────────────────────────────────────────────────────────────────
# X-Internal-Token: shared secret between bot process and FastAPI (same process)
INTERNAL_TOKEN=change_me_to_random_32_chars_secret
# JWT for Web UI sessions
JWT_SECRET=change_me_to_another_random_32_chars
JWT_EXPIRE_MINUTES=10080           # 7 days

# ─── Web UI ───────────────────────────────────────────────────────────────────
WEB_ADMIN_USER=admin
WEB_ADMIN_PASSWORD=changeme        # CHANGE THIS!

# ─── Sing-Box ─────────────────────────────────────────────────────────────────
SINGBOX_CONFIG_PATH=/etc/sing-box/config.json
SINGBOX_CONTAINER=singbox_core     # docker container name for exec/restart

# ─── AdGuard Home ─────────────────────────────────────────────────────────────
ADGUARD_URL=http://adguard:3000
ADGUARD_USER=admin
ADGUARD_PASSWORD=changeme

# ─── Nginx / SSL ──────────────────────────────────────────────────────────────
DOMAIN=vpn.example.com             # your domain (must point to this server)
EMAIL=admin@example.com            # for Let's Encrypt notifications

# ─── Federation ───────────────────────────────────────────────────────────────
FEDERATION_SECRET=change_me_federation_secret_32_chars
BOT_PUBLIC_URL=https://vpn.example.com

# ─── App ──────────────────────────────────────────────────────────────────────
SECRET_KEY=change_me_app_secret_key_32_chars
TZ=UTC
BOT_LANG=ru                        # ru | en
WEBHOOK_HOST=                      # empty = polling mode; set to https://vpn.example.com for webhook
WEBHOOK_PATH=/webhook
WEBHOOK_PORT=8080
