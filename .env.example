# Telegram Bot
BOT_TOKEN=your_telegram_bot_token_here
ADMIN_IDS=123456789,987654321

# s-ui API
SUI_URL=http://sui:2095
SUI_USERNAME=admin
SUI_PASSWORD=admin
# Bearer token (generated after first login, preferred over password)
SUI_TOKEN=

# AdGuard Home
ADGUARD_URL=http://adguard:3000
ADGUARD_USER=admin
ADGUARD_PASSWORD=changeme

# Nginx & SSL
DOMAIN=example.com
EMAIL=admin@example.com
# Stub mode: auth (native browser 401 dialog) | custom (your HTML) | none (404)
STUB_MODE=auth

# Federation
FEDERATION_SECRET=change_this_to_random_secret_32chars
BOT_PUBLIC_URL=https://example.com

# Security
SECRET_KEY=change_this_to_random_key_32chars

# Timezone
TZ=UTC

# Bot language (ru / en)
BOT_LANG=ru

# Webhook (leave empty for polling)
WEBHOOK_HOST=
WEBHOOK_PATH=/webhook
WEBHOOK_PORT=8080
