# ─── Telegram Bot ─────────────────────────────────────────────────────────────
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# No ADMIN_IDS — first /start registers the owner as admin via bot wizard

# ─── API Auth (auto-generated by install.sh — do not share) ──────────────────
INTERNAL_TOKEN=change_me_to_random_32_chars_secret
JWT_SECRET=change_me_to_another_random_32_chars
JWT_EXPIRE_MINUTES=10080           # 7 days

# ─── Web UI initial credentials ───────────────────────────────────────────────
WEB_ADMIN_USER=admin
WEB_ADMIN_PASSWORD=changeme        # auto-generated random by install.sh

# ─── Sing-Box ─────────────────────────────────────────────────────────────────
SINGBOX_CONFIG_PATH=/etc/sing-box/config.json
SINGBOX_CONTAINER=singbox_core

# ─── AdGuard Home ─────────────────────────────────────────────────────────────
ADGUARD_URL=http://adguard:3000
ADGUARD_USER=admin
ADGUARD_PASSWORD=changeme

# ─── Federation ───────────────────────────────────────────────────────────────
FEDERATION_SECRET=change_me_federation_secret_32_chars
BOT_PUBLIC_URL=                    # populated automatically when domain is set

# ─── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change_me_app_secret_key_32_chars

# ─── Webhook (empty = polling mode) ───────────────────────────────────────────
WEBHOOK_HOST=                      # set automatically when domain is configured
WEBHOOK_PATH=/webhook
WEBHOOK_PORT=8080

# ─────────────────────────────────────────────────────────────────────────────
# Domain, timezone and bot language are configured via the bot on first /start.
# They live ONLY in the database — never in this file.
# ─────────────────────────────────────────────────────────────────────────────
