# ─── Telegram Bot ─────────────────────────────────────────────────────────────
BOT_TOKEN=1234567890:AAxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
# NOTE: No ADMIN_IDS here. The first user to send /start becomes the admin.

# ─── API Auth ─────────────────────────────────────────────────────────────────
# X-Internal-Token: shared secret between bot process and FastAPI
INTERNAL_TOKEN=change_me_to_random_32_chars_secret
# JWT for Web UI sessions
JWT_SECRET=change_me_to_another_random_32_chars
JWT_EXPIRE_MINUTES=10080           # 7 days

# ─── Web UI ───────────────────────────────────────────────────────────────────
WEB_ADMIN_USER=admin
WEB_ADMIN_PASSWORD=changeme        # CHANGE THIS!

# ─── Sing-Box ─────────────────────────────────────────────────────────────────
SINGBOX_CONFIG_PATH=/etc/sing-box/config.json
SINGBOX_CONTAINER=singbox_core

# ─── AdGuard Home ─────────────────────────────────────────────────────────────
ADGUARD_URL=http://adguard:3000
ADGUARD_USER=admin
ADGUARD_PASSWORD=changeme

# ─── SSL ──────────────────────────────────────────────────────────────────────
EMAIL=admin@example.com            # for Let's Encrypt notifications only

# ─── Federation ───────────────────────────────────────────────────────────────
FEDERATION_SECRET=change_me_federation_secret_32_chars
BOT_PUBLIC_URL=https://your-domain.example.com

# ─── Security ─────────────────────────────────────────────────────────────────
SECRET_KEY=change_me_app_secret_key_32_chars

# ─── Webhook (leave empty for polling mode) ───────────────────────────────────
WEBHOOK_HOST=                      # e.g. https://your-domain.example.com
WEBHOOK_PATH=/webhook
WEBHOOK_PORT=8080

# ─────────────────────────────────────────────────────────────────────────────
# NOTE: domain, timezone and bot language are NOT stored here.
# They are collected during installation and written directly to the database
# (data/app.db → AppSetting table).  Change them anytime via the bot or Web UI.
# ─────────────────────────────────────────────────────────────────────────────
