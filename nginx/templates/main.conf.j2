{% set sui_path = '/' + secret_hash[:12] + '/panel' %}
{% set sub_path = '/' + secret_hash[12:24] + '/sub' %}
{% set adguard_path = '/' + secret_hash[24:36] + '/adg' %}
{% set fed_path = '/' + secret_hash[36:48] + '/api' %}

# Redirect HTTP → HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name {{ domain }};

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ domain }};

    ssl_certificate     {{ ssl_cert }};
    ssl_certificate_key {{ ssl_key }};
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 10m;
    server_tokens       off;

    # Security headers
    add_header X-Frame-Options   "SAMEORIGIN"   always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy   "no-referrer"  always;

    # Logs
    access_log /var/log/nginx/access.log;
    error_log  /var/log/nginx/error.log warn;

    # ── Root: serve override/index.html if uploaded, else 401 auth popup ──────
    root /var/www/override;

    location = / {
        # If user uploaded override/index.html — show it, otherwise 401 popup
        try_files /index.html @auth;
    }

    # Static assets that override page may reference (CSS, images, fonts…)
    location /override/ {
        alias /var/www/override/;
        try_files $uri =404;
    }

    # Named location: shows browser's native HTTP Basic Auth dialog
    # htpasswd contains a random hash — real login is impossible (camouflage)
    location @auth {
        auth_basic           "Restricted Content";
        auth_basic_user_file /etc/nginx/.htpasswd;
        try_files            /dev/null =403;
    }

    # ── Hidden service paths (hash-based) ─────────────────────────────────────

    # s-ui panel
    location {{ sui_path }}/ {
        proxy_pass         http://sui:2095/;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection "upgrade";
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 86400;
    }

    # Subscriptions
    location {{ sub_path }}/ {
        proxy_pass         http://sui:2096/sub/;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    {% if adguard_enabled %}
    # AdGuard Home
    location {{ adguard_path }}/ {
        proxy_pass         http://adguard:3000/;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection "upgrade";
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }
    {% endif %}

    # Federation API
    location {{ fed_path }}/ {
        proxy_pass         http://bot:8080/federation/;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }
}
