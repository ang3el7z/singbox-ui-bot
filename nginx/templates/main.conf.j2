{% set web_path  = '/' + secret_hash[:12] + '/web' %}
{% set sub_path  = '/' + secret_hash[12:24] + '/sub' %}
{% set adguard_path = '/' + secret_hash[24:36] + '/adg' %}
{% set api_path  = '/' + secret_hash[36:48] + '/api' %}

# Redirect HTTP → HTTPS
server {
    listen 80;
    listen [::]:80;
    server_name {{ domain }};

    location /.well-known/acme-challenge/ {
        root /var/www/certbot;
    }

    location / {
        return 301 https://$host$request_uri;
    }
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ domain }};

    ssl_certificate     {{ ssl_cert }};
    ssl_certificate_key {{ ssl_key }};
    ssl_protocols       TLSv1.2 TLSv1.3;
    ssl_ciphers         HIGH:!aNULL:!MD5;
    ssl_session_cache   shared:SSL:10m;
    ssl_session_timeout 10m;
    server_tokens       off;

    # Security headers
    add_header X-Frame-Options   "SAMEORIGIN"   always;
    add_header X-Content-Type-Options "nosniff" always;
    add_header Referrer-Policy   "no-referrer"  always;

    # Logs
    access_log /var/log/nginx/access.log;
    error_log  /var/log/nginx/error.log warn;

    # ── IP deny list (managed via bot/UI → Maintenance → IP Ban) ─────────────
    {% for ip in banned_ips %}
    deny {{ ip }};
    {% endfor %}
    {% if banned_ips %}
    allow all;
    {% endif %}

    # ── Root: configurable public site (toggle via bot/UI) ────────────────────
    root /var/www/override;

    location = / {
        {% if site_enabled %}
        # Site is ON — serve override/index.html if uploaded, fall back to 401 popup
        try_files /index.html @auth;
        {% else %}
        # Site is OFF (default) — always show 401 Basic Auth popup (camouflage)
        try_files /dev/null @auth;
        {% endif %}
    }

    # Static assets that override page may reference (CSS, images, fonts…)
    location /override/ {
        {% if site_enabled %}
        alias /var/www/override/;
        try_files $uri =404;
        {% else %}
        return 404;
        {% endif %}
    }

    # Named location: shows browser's native HTTP Basic Auth dialog
    # htpasswd contains a random hash — real login is always impossible (camouflage)
    location @auth {
        auth_basic           "Restricted Content";
        auth_basic_user_file /etc/nginx/htpasswd/.htpasswd;
        try_files            /dev/null =403;
    }

    # ── Web UI ────────────────────────────────────────────────────────────────
    location /web/ {
        alias /var/www/web/;
        try_files $uri $uri/ /web/index.html;
    }

    # ── API (hidden path) ────────────────────────────────────────────────────
    location {{ api_path }}/ {
        proxy_pass         http://app:8080/api/;
        proxy_http_version 1.1;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    # Public API (needed by web UI at /api/*)
    location /api/ {
        proxy_pass         http://app:8080/api/;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection "upgrade";
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
        proxy_read_timeout 120;
    }

    # Webhook
    location /webhook {
        proxy_pass         http://app:8080/webhook;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_read_timeout 120;
    }

    # Public subscriptions — proxied to /api/sub/{sub_id}
    # JSON config:   https://domain/{hash}/sub/{sub_id}
    # WinSW XML:     https://domain/{hash}/sub/{sub_id}/winsw.xml
    location ~ ^{{ sub_path }}/(.+)$ {
        proxy_pass         http://app:8080/api/sub/$1$is_args$args;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }

    {% if adguard_enabled %}
    # AdGuard Home
    location {{ adguard_path }}/ {
        proxy_pass         http://adguard:3000/;
        proxy_http_version 1.1;
        proxy_set_header   Upgrade $http_upgrade;
        proxy_set_header   Connection "upgrade";
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }
    {% endif %}

    # Federation HMAC API
    location /federation/ {
        proxy_pass         http://app:8080/federation/;
        proxy_set_header   Host $host;
        proxy_set_header   X-Real-IP $remote_addr;
        proxy_set_header   X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header   X-Forwarded-Proto $scheme;
    }
}
