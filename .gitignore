# Reference repositories (examples only)
example/

# Secrets and local config
.env
*.env.local

# Runtime data
data/

# Python cache
__pycache__/
*.pyc
*.pyo
*.pyd
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
dist/
build/
venv/
.venv/

# Nginx generated/runtime files
nginx/conf.d/*.conf
nginx/logs/
nginx/override/       # user-uploaded stub site (managed via bot)
nginx/htpasswd/       # generated .htpasswd with random creds

# Database files
*.db
*.db-shm
*.db-wal

# OS files
.DS_Store
Thumbs.db

# IDE
.idea/
.vscode/
*.swp
*.swo

# Certificates (managed by certbot/Let's Encrypt)
data/certs/
nginx/certs/

# Subscriptions (generated at runtime)
subs/

# Sing-Box cache
config/sing-box/cache.db

# AdGuard runtime data (persisted in Docker volume, seed config is in git)
# Only AdGuardHome.yaml seed is tracked; AdGuard writes its runtime files here too
config/adguard/AdGuardHome.yaml.tmp
config/adguard/*.db
config/adguard/*.bak
