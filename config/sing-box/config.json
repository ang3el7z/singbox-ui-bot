{
  "log": {
    "level": "info",
    "timestamp": true,
    "output": "/var/log/sing-box/sing-box.log"
  },
  "dns": {
    "servers": [
      {
        "tag": "dns_adguard",
        "address": "udp://127.0.0.1",
        "strategy": "prefer_ipv4",
        "detour": "direct"
      },
      {
        "tag": "dns_fallback",
        "address": "udp://8.8.8.8",
        "detour": "direct"
      }
    ],
    "rules": [
      {
        "outbound": "any",
        "server": "dns_adguard"
      }
    ],
    "final": "dns_adguard",
    "independent_cache": true
  },
  "inbounds": [],
  "outbounds": [
    {
      "tag": "proxy",
      "type": "selector",
      "outbounds": ["direct", "block"],
      "default": "direct"
    },
    {
      "tag": "direct",
      "type": "direct"
    },
    {
      "tag": "block",
      "type": "block"
    },
    {
      "tag": "dns-out",
      "type": "dns"
    }
  ],
  "route": {
    "rules": [
      {
        "protocol": "dns",
        "outbound": "dns-out"
      },
      {
        "ip_is_private": true,
        "outbound": "direct"
      }
    ],
    "rule_set": [],
    "final": "proxy",
    "auto_detect_interface": true
  },
  "experimental": {
    "v2ray_api": {
      "listen": "127.0.0.1:8811",
      "stats": {
        "enabled": true,
        "inbounds": [],
        "outbounds": ["proxy", "direct", "block"],
        "users": []
      }
    },
    "cache_file": {
      "enabled": true,
      "path": "/etc/sing-box/cache.db"
    }
  }
}
